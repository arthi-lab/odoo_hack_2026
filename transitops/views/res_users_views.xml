<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_transitops" model="ir.ui.view">
        <field name="name">res.users.form.transitops</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='page_security']" position="inside">
                <group string="TransitOps Security Settings">
                    <field name="failed_login_attempts" string="Failed Login Attempts (Lock at 5)"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
